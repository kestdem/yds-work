{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() == true",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('isAdmin').val() == true)",
        ".write": "auth != null && ((auth.uid == $uid && !data.exists() && newData.child('isAdmin').val() == false && newData.child('isApproved').val() == false) || root.child('users').child(auth.uid).child('isAdmin').val() == true)"
      }
    },
    "questions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isApproved').val() == true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() == true"
    }
  }
}
